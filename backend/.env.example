# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/linkedreach
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=linkedreach

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Encryption key for LinkedIn session cookies
ENCRYPTION_KEY=32-char-encryption-key-here-change
